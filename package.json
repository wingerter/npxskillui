{
  "name": "skillui",
  "version": "1.3.4",
  "description": "Reverse-engineer design systems from any website, repo, or project. Extracts colors, fonts, spacing, animations, and components - packaged as a .skill file for Claude. Pure static analysis, zero AI, zero API keys.",
  "main": "dist/cli.js",
  "bin": {
    "skillui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "static-analysis",
    "css",
    "tailwind",
    "cli",
    "claude",
    "claude-code",
    "skill",
    "ui",
    "figma",
    "reverse-engineer",
    "animations",
    "playwright"
  ],
  "author": "Amaan",
  "license": "MIT",
  "homepage": "https://skillui.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/amaancoderx/npxskillui.git"
  },
  "bugs": {
    "url": "https://github.com/amaancoderx/npxskillui/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "archiver": "^7.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "css-tree": "^2.3.1",
    "culori": "^4.0.0",
    "glob": "^10.3.0",
    "gradient-string": "^3.0.0",
    "jiti": "^1.21.0",
    "oh-my-logo": "^0.4.0",
    "ora": "^8.2.0",
    "postcss": "^8.4.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.24.0",
    "strip-ansi": "^7.2.0",
    "tmp": "^0.2.3",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/cli-progress": "^3.11.6",
    "@types/css-tree": "^2.3.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/tmp": "^0.2.6",
    "playwright": "^1.59.1",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "playwright": "^1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "skillui.png"
  ]
}
